{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "sam/**/*", "use": "@vercel/static" },
    { "src": "vr/**/*", "use": "@vercel/static" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/sam", "destination": "/sam/index.html" },
    { "source": "/sam/chat", "destination": "/sam/chat.html" },
    { "source": "/api/embed", "destination": "/api/embed.js" },
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/manifest.json", "destination": "/public/manifest.json" },
    { "source": "/quotes.json", "destination": "/public/quotes.json" },
    { "source": "/vocabulary.json", "destination": "/public/vocabulary.json" },
    { "source": "/sig/:path*", "destination": "/public/sig/:path*" },
    { "source": "/images/:path*", "destination": "/public/images/:path*" },
    { "source": "/audio/:path*", "destination": "/public/audio/:path*" }
  ]
}
